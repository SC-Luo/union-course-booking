# 資料來源設定：json (本地 JSON 備份檔) 或 firestore (Firestore 資料庫)
# 日常開發調試與單元測試時，強烈建議保持為 json 或連線至 Staging 測試資料庫！
# 嚴禁在日常開發中將本地環境直接連線至生產 Production 專案！
BOOKING_DATA_SOURCE=json

# Firebase Admin SDK 憑證 (如要連線至 Firestore 測試，建議使用 Staging 專案憑證)
FIREBASE_PROJECT_ID=your-staging-project-id
FIREBASE_CLIENT_EMAIL=your-staging-client-email
FIREBASE_PRIVATE_KEY="your-staging-private-key"

# 後台管理者密碼與 session 安全憑證 (本地開發專用)
ADMIN_PASSWORD=admin-password-for-local
ADMIN_SESSION_SECRET=some-secret-key-for-local

